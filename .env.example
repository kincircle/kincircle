# Required for app and auth routes
DATABASE_URL=postgresql://user:password@localhost:5432/kincircle
BETTER_AUTH_SECRET=replace-with-a-random-32-plus-character-secret
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: enable Google OAuth only when both values are set
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Required for magic-link and invite emails
RESEND_API_KEY=
EMAIL_FROM='KinCircle <onboarding@resend.dev>'

# Required when geocoding and location suggestions are enabled
MAPBOX_ACCESS_TOKEN=
